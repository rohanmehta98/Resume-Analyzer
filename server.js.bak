const path = require("path");
const express = require("express");
const dotenv = require("dotenv");

dotenv.config();

const app = express();
const PORT = Number(process.env.PORT || 3000);
const GEMINI_API_KEY = process.env.GEMINI_API_KEY || "";
const GEMINI_MODEL = process.env.GEMINI_MODEL || "gemini-2.5-flash";
const PUBLIC_DIR = path.join(__dirname, "public");

app.disable("x-powered-by");
app.use(express.json({ limit: "4mb" }));
app.use(express.static(PUBLIC_DIR, { extensions: ["html"] }));

app.get("/api/health", (_req, res) => {
  res.json({
    ok: true,
    configured: Boolean(GEMINI_API_KEY),
    model: GEMINI_MODEL,
    runtime: "server-secured"
  });
});

app.post("/api/analyze", async (req, res) => {
  if (!GEMINI_API_KEY) {
    res.status(500).json({
      ok: false,
      error: "The server is missing GEMINI_API_KEY. Add it to your .env file before running the app."
    });
    return;
  }

  try {
    const input = validateRequest(req.body);
    const rawAnalysis = await requestGeminiAnalysis(input);
    const analysis = normalizeAnalysis(rawAnalysis, input);

    res.json({
      ok: true,
      analysis,
      meta: {
        model: GEMINI_MODEL,
        storage: "No resume data is stored. Requests are processed in memory only."
      }
    });
  } catch (error) {
    console.error("Analysis error:", error);
    res.status(error.statusCode || 500).json({
      ok: false,
      error: error.publicMessage || error.message || "Unable to analyze the resume right now."
    });
  }
});

app.use((_req, res) => {
  res.sendFile(path.join(PUBLIC_DIR, "index.html"));
});

app.listen(PORT, () => {
  console.log(`ResumeIQ secure server running on http://localhost:${PORT}`);
});

function validateRequest(body) {
  const resumeText = cleanTextBlock(body?.resumeText);
  const fileName = cleanText(body?.fileName) || "resume";
  const targetRole = cleanText(body?.targetRole);
  const targetIndustry = cleanText(body?.targetIndustry);
  const experienceLevel = cleanText(body?.experienceLevel);
  const jobDescription = cleanTextBlock(body?.jobDescription);
  const focusQuestions = Array.isArray(body?.focusQuestions)
    ? body.focusQuestions.map(cleanText).filter(Boolean).slice(0, 3)
    : [];

  if (!resumeText || resumeText.length < 120) {
    const error = new Error("Please upload a readable resume with enough text to analyze.");
    error.statusCode = 400;
    error.publicMessage = error.message;
    throw error;
  }

  return {
    resumeText,
    fileName,
    targetRole,
    targetIndustry,
    experienceLevel,
    jobDescription,
    focusQuestions
  };
}

async function requestGeminiAnalysis(input) {
  const url = `https://generativelanguage.googleapis.com/v1beta/models/${encodeURIComponent(GEMINI_MODEL)}:generateContent`;
  const prompt = buildPrompt(input);
  const baseGenerationConfig = {
    responseMimeType: "application/json",
    temperature: 0.25,
    topP: 0.9,
    maxOutputTokens: 4096
  };

  const payloadWithSchema = {
    contents: [
      {
        role: "user",
        parts: [{ text: prompt }]
      }
    ],
    generationConfig: {
      ...baseGenerationConfig,
      responseSchema: buildResponseSchema()
    }
  };

  try {
    return await callGemini(url, payloadWithSchema);
  } catch (error) {
    if (!error.retryWithoutSchema) {
      throw error;
    }

    return callGemini(url, {
      contents: payloadWithSchema.contents,
      generationConfig: baseGenerationConfig
    });
  }
}

async function callGemini(url, payload) {
  const response = await fetch(url, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "x-goog-api-key": GEMINI_API_KEY
    },
    body: JSON.stringify(payload)
  });

  const body = await response.json().catch(() => ({}));

  if (!response.ok) {
    const error = buildGeminiError(response.status, body);
    throw error;
  }

  const text = extractGeminiText(body);
  if (!text) {
    const error = new Error("Gemini returned an empty response.");
    error.statusCode = 502;
    error.publicMessage = "The AI service returned an empty response. Please try again.";
    throw error;
  }

  return parseJsonResponse(text);
}

function buildGeminiError(statusCode, body) {
  const message = body?.error?.message || "";
  const normalized = message.toLowerCase();
  const error = new Error(message || "Gemini request failed.");
  error.statusCode = [400, 401, 403, 429].includes(statusCode) ? statusCode : 502;

  if (statusCode === 400 && normalized.includes("api key")) {
    error.publicMessage = "Gemini rejected the configured API key. Check the key in .env and try again.";
  } else if (statusCode === 401 || statusCode === 403) {
    error.publicMessage = "Gemini denied access for the configured API key.";
  } else if (statusCode === 429) {
    error.publicMessage = "Gemini quota or rate limits were hit. Please retry shortly.";
  } else if (statusCode >= 500) {
    error.publicMessage = "Gemini is temporarily unavailable. Please retry in a moment.";
  } else {
    error.publicMessage = message || "Gemini could not process this resume right now.";
  }

  if (
    statusCode === 400 &&
    (normalized.includes("responseschema") ||
      normalized.includes("schema") ||
      normalized.includes("propertyordering") ||
      normalized.includes("generationconfig"))
  ) {
    error.retryWithoutSchema = true;
  }

  return error;
}

function extractGeminiText(responseBody) {
  const candidate = responseBody?.candidates?.[0];
  const parts = candidate?.content?.parts;
  const textPart = Array.isArray(parts) ? parts.find((part) => typeof part?.text === "string") : null;
  return textPart?.text?.trim() || "";
}

function parseJsonResponse(text) {
  try {
    return JSON.parse(text);
  } catch {
    const match = text.match(/\{[\s\S]*\}/);
    if (match) {
      return JSON.parse(match[0]);
    }
  }

  const error = new Error("Gemini returned invalid JSON.");
  error.statusCode = 502;
  error.publicMessage = "The AI response was malformed. Please try again.";
  throw error;
}

function buildPrompt(input) {
  const hasJobDescription = Boolean(input.jobDescription);
  const hasQuestions = input.focusQuestions.length > 0;

  return [
    "You are ResumeIQ, an expert recruiter, ATS auditor, and resume strategist.",
    "Analyze the resume in an industry-aware way and respond with exactly one JSON object.",
    "Do not include markdown. Do not wrap the JSON in code fences. Do not add commentary outside the JSON.",
    "All scores must be integers from 0 to 100.",
    "Use concise, direct language that is useful to a real applicant.",
    "If the resume lacks evidence, infer carefully and call out the gap.",
    hasJobDescription
      ? "Use the supplied job description to evaluate alignment and keyword coverage."
      : "No job description is provided. Infer fit from the resume content and the target role or industry if given.",
    hasQuestions
      ? "Answer the user's focus questions inside customInsights with one clear answer per question."
      : "Return an empty customInsights array if the user did not ask any questions.",
    "Allowed enums:",
    'overallVerdict: "Excellent Match" | "Promising Match" | "Needs Revision"',
    'screeningOutlook: "Ready to Apply" | "Apply After Revisions" | "Needs Major Improvements"',
    'recommendations[].priority: "High" | "Medium" | "Low"',
    "JSON contract:",
    JSON.stringify(buildPromptShape()),
    "",
    `Resume file name: ${input.fileName}`,
    `Target role: ${input.targetRole || "Not provided"}`,
    `Target industry: ${input.targetIndustry || "Not provided"}`,
    `Experience level: ${input.experienceLevel || "Not provided"}`,
    `Job description: ${input.jobDescription || "Not provided"}`,
    `User focus questions: ${input.focusQuestions.length ? input.focusQuestions.join(" | ") : "None"}`,
    "",
    "Resume text:",
    input.resumeText
  ].join("\n");
}

function buildPromptShape() {
  return {
    candidateName: "string",
    detectedRole: "string",
    industryFit: "string",
    overallScore: "number 0-100",
    overallVerdict: "Excellent Match | Promising Match | Needs Revision",
    executiveSummary: "string",
    sectionScores: {
      experience: { score: "number", insight: "string" },
      education: { score: "number", insight: "string" },
      skills: { score: "number", insight: "string" },
      impact: { score: "number", insight: "string" },
      formatting: { score: "number", insight: "string" },
      keywordFit: { score: "number", insight: "string" }
    },
    ats: {
      score: "number 0-100",
      summary: "string",
      checks: {
        fileFormatCompatible: "boolean",
        standardHeadings: "boolean",
        readableLayout: "boolean",
        keywordCoverage: "boolean",
        contactInfoPresent: "boolean",
        dateFormatsClear: "boolean"
      }
    },
    strengths: ["string"],
    gaps: ["string"],
    matchedKeywords: ["string"],
    missingKeywords: ["string"],
    recommendations: [
      {
        priority: "High | Medium | Low",
        title: "string",
        detail: "string"
      }
    ],
    customInsights: [
      {
        question: "string",
        answer: "string"
      }
    ],
    likelyInterviewQuestions: ["string"],
    finalVerdict: "string",
    screeningOutlook: "Ready to Apply | Apply After Revisions | Needs Major Improvements"
  };
}

function buildResponseSchema() {
  return {
    type: "OBJECT",
    required: [
      "candidateName",
      "detectedRole",
      "industryFit",
      "overallScore",
      "overallVerdict",
      "executiveSummary",
      "sectionScores",
      "ats",
      "strengths",
      "gaps",
      "matchedKeywords",
      "missingKeywords",
      "recommendations",
      "customInsights",
      "likelyInterviewQuestions",
      "finalVerdict",
      "screeningOutlook"
    ],
    properties: {
      candidateName: { type: "STRING" },
      detectedRole: { type: "STRING" },
      industryFit: { type: "STRING" },
      overallScore: { type: "NUMBER" },
      overallVerdict: {
        type: "STRING",
        enum: ["Excellent Match", "Promising Match", "Needs Revision"]
      },
      executiveSummary: { type: "STRING" },
      sectionScores: {
        type: "OBJECT",
        required: ["experience", "education", "skills", "impact", "formatting", "keywordFit"],
        properties: {
          experience: scoreNode(),
          education: scoreNode(),
          skills: scoreNode(),
          impact: scoreNode(),
          formatting: scoreNode(),
          keywordFit: scoreNode()
        }
      },
      ats: {
        type: "OBJECT",
        required: ["score", "summary", "checks"],
        properties: {
          score: { type: "NUMBER" },
          summary: { type: "STRING" },
          checks: {
            type: "OBJECT",
            required: [
              "fileFormatCompatible",
              "standardHeadings",
              "readableLayout",
              "keywordCoverage",
              "contactInfoPresent",
              "dateFormatsClear"
            ],
            properties: {
              fileFormatCompatible: { type: "BOOLEAN" },
              standardHeadings: { type: "BOOLEAN" },
              readableLayout: { type: "BOOLEAN" },
              keywordCoverage: { type: "BOOLEAN" },
              contactInfoPresent: { type: "BOOLEAN" },
              dateFormatsClear: { type: "BOOLEAN" }
            }
          }
        }
      },
      strengths: { type: "ARRAY", items: { type: "STRING" } },
      gaps: { type: "ARRAY", items: { type: "STRING" } },
      matchedKeywords: { type: "ARRAY", items: { type: "STRING" } },
      missingKeywords: { type: "ARRAY", items: { type: "STRING" } },
      recommendations: {
        type: "ARRAY",
        items: {
          type: "OBJECT",
          required: ["priority", "title", "detail"],
          properties: {
            priority: { type: "STRING", enum: ["High", "Medium", "Low"] },
            title: { type: "STRING" },
            detail: { type: "STRING" }
          }
        }
      },
      customInsights: {
        type: "ARRAY",
        items: {
          type: "OBJECT",
          required: ["question", "answer"],
          properties: {
            question: { type: "STRING" },
            answer: { type: "STRING" }
          }
        }
      },
      likelyInterviewQuestions: { type: "ARRAY", items: { type: "STRING" } },
      finalVerdict: { type: "STRING" },
      screeningOutlook: {
        type: "STRING",
        enum: ["Ready to Apply", "Apply After Revisions", "Needs Major Improvements"]
      }
    }
  };
}

function scoreNode() {
  return {
    type: "OBJECT",
    required: ["score", "insight"],
    properties: {
      score: { type: "NUMBER" },
      insight: { type: "STRING" }
    }
  };
}

function normalizeAnalysis(raw, input) {
  const sectionScores = normalizeSectionScores(raw?.sectionScores);
  const atsChecks = normalizeAtsChecks(raw?.ats?.checks, input.resumeText, input.fileName);
  const focusQuestions = input.focusQuestions;

  return {
    candidateName: cleanText(raw?.candidateName) || guessCandidateName(input.resumeText),
    detectedRole: cleanText(raw?.detectedRole) || input.targetRole || guessRole(input.resumeText),
    industryFit: cleanText(raw?.industryFit) || fallbackIndustryFit(input),
    overallScore: normalizeScore(raw?.overallScore),
    overallVerdict: normalizeOverallVerdict(raw?.overallVerdict, raw?.overallScore),
    executiveSummary:
      cleanSentence(raw?.executiveSummary) ||
      buildExecutiveSummary(normalizeScore(raw?.overallScore), sectionScores),
    sectionScores,
    ats: {
      score: normalizeScore(raw?.ats?.score ?? calculateAtsScore(atsChecks)),
      summary:
        cleanSentence(raw?.ats?.summary) ||
        "The resume was checked for ATS-safe structure, contact completeness, keyword coverage, and readable chronology.",
      checks: atsChecks
    },
    strengths: normalizeStringList(raw?.strengths, 5, buildStrengthFallback(sectionScores)),
    gaps: normalizeStringList(raw?.gaps, 5, buildGapFallback(sectionScores)),
    matchedKeywords: normalizeStringList(raw?.matchedKeywords, 12, extractKeywordCandidates(input.resumeText, 10)),
    missingKeywords: normalizeStringList(raw?.missingKeywords, 12, input.jobDescription ? [] : []),
    recommendations: normalizeRecommendations(raw?.recommendations, sectionScores),
    customInsights: normalizeCustomInsights(raw?.customInsights, focusQuestions),
    likelyInterviewQuestions: normalizeStringList(
      raw?.likelyInterviewQuestions,
      5,
      buildInterviewQuestionFallback(input)
    ),
    finalVerdict:
      cleanSentence(raw?.finalVerdict) ||
      buildFinalVerdict(normalizeScore(raw?.overallScore), input.targetRole || guessRole(input.resumeText)),
    screeningOutlook: normalizeScreeningOutlook(raw?.screeningOutlook, raw?.overallScore)
  };
}

function normalizeSectionScores(sectionScores = {}) {
  const defaults = {
    experience: "Experience should show stronger scope, clarity, and measurable ownership.",
    education: "Education is present but could be framed more clearly for relevance.",
    skills: "Skills are listed, though the alignment to the target role could be sharper.",
    impact: "Business impact needs stronger numbers, outcomes, or proof points.",
    formatting: "Formatting is readable overall, but small structural improvements would help screening.",
    keywordFit: "Keyword coverage exists, but the language can be tuned more closely to hiring filters."
  };

  const normalized = {};

  Object.keys(defaults).forEach((key) => {
    normalized[key] = {
      score: normalizeScore(sectionScores?.[key]?.score),
      insight: cleanSentence(sectionScores?.[key]?.insight) || defaults[key]
    };
  });

  return normalized;
}

function normalizeAtsChecks(checks = {}, resumeText, fileName) {
  const lowerFileName = String(fileName || "").toLowerCase();
  return {
    fileFormatCompatible: booleanWithFallback(checks.fileFormatCompatible, lowerFileName.endsWith(".pdf") || lowerFileName.endsWith(".docx")),
    standardHeadings: booleanWithFallback(checks.standardHeadings, /experience|education|skills|projects|summary/i.test(resumeText)),
    readableLayout: booleanWithFallback(checks.readableLayout, !/table|graphic|text box/i.test(resumeText)),
    keywordCoverage: booleanWithFallback(checks.keywordCoverage, resumeText.split(/\s+/).length > 180),
    contactInfoPresent: booleanWithFallback(checks.contactInfoPresent, /@|\+?\d[\d\s().-]{8,}/.test(resumeText)),
    dateFormatsClear: booleanWithFallback(checks.dateFormatsClear, /\b(?:jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)[a-z]*\b|\b(19|20)\d{2}\b/i.test(resumeText))
  };
}

function normalizeRecommendations(recommendations, sectionScores) {
  const items = Array.isArray(recommendations) ? recommendations : [];
  const normalized = items
    .map((item) => ({
      priority: normalizePriority(item?.priority),
      title: cleanText(item?.title),
      detail: cleanSentence(item?.detail)
    }))
    .filter((item) => item.title && item.detail);

  const fallback = buildRecommendationFallback(sectionScores);
  const merged = [...normalized];

  fallback.forEach((item) => {
    if (merged.length >= 6) {
      return;
    }

    const exists = merged.some((entry) => entry.title.toLowerCase() === item.title.toLowerCase());
    if (!exists) {
      merged.push(item);
    }
  });

  return merged.slice(0, 6);
}

function normalizeCustomInsights(customInsights, questions) {
  const incoming = Array.isArray(customInsights) ? customInsights : [];
  const normalized = incoming
    .map((item) => ({
      question: cleanText(item?.question),
      answer: cleanSentence(item?.answer)
    }))
    .filter((item) => item.question && item.answer);

  if (normalized.length > 0) {
    return normalized.slice(0, 3);
  }

  return questions.map((question) => ({
    question,
    answer: "This concern needs a closer pass during revision. Use the main recommendations and keyword analysis above to strengthen this area before applying."
  }));
}

function normalizeStringList(values, maxItems, fallback) {
  const primary = Array.isArray(values) ? values : [];
  const backup = Array.isArray(fallback) ? fallback : [];
  return [...new Set([...primary, ...backup].map(cleanText).filter(Boolean))].slice(0, maxItems);
}

function normalizeScore(value) {
  const numeric = Number.parseInt(value, 10);
  if (Number.isNaN(numeric)) {
    return 0;
  }

  return Math.max(0, Math.min(100, numeric));
}

function normalizeOverallVerdict(value, scoreValue) {
  const score = normalizeScore(scoreValue);
  if (value === "Excellent Match" || value === "Promising Match" || value === "Needs Revision") {
    return value;
  }

  if (score >= 75) return "Excellent Match";
  if (score >= 50) return "Promising Match";
  return "Needs Revision";
}

function normalizeScreeningOutlook(value, scoreValue) {
  if (value === "Ready to Apply" || value === "Apply After Revisions" || value === "Needs Major Improvements") {
    return value;
  }

  const score = normalizeScore(scoreValue);
  if (score >= 75) return "Ready to Apply";
  if (score >= 50) return "Apply After Revisions";
  return "Needs Major Improvements";
}

function normalizePriority(value) {
  if (value === "High" || value === "Medium" || value === "Low") {
    return value;
  }

  return "Medium";
}

function buildStrengthFallback(sectionScores) {
  return Object.entries(sectionScores)
    .sort((a, b) => b[1].score - a[1].score)
    .slice(0, 5)
    .map(([key, data]) => `${prettySectionName(key)}: ${data.insight}`);
}

function buildGapFallback(sectionScores) {
  return Object.entries(sectionScores)
    .sort((a, b) => a[1].score - b[1].score)
    .slice(0, 5)
    .map(([key, data]) => `${prettySectionName(key)}: ${data.insight}`);
}

function buildRecommendationFallback(sectionScores) {
  return Object.entries(sectionScores)
    .sort((a, b) => a[1].score - b[1].score)
    .slice(0, 4)
    .map(([key, data]) => ({
      priority: data.score < 45 ? "High" : data.score < 65 ? "Medium" : "Low",
      title: `Strengthen ${prettySectionName(key)}`,
      detail: `${data.insight} Rewrite this section with tighter evidence, clearer language, and stronger alignment to the role.`
    }));
}

function buildInterviewQuestionFallback(input) {
  const role = input.targetRole || guessRole(input.resumeText);
  return [
    `What examples best prove your impact for ${role}?`,
    "Which metrics can you add to show results more clearly?",
    "How would you explain your strongest technical or domain skills in one minute?",
    "What parts of your background are most relevant to the target role?",
    "Where might a recruiter ask for clarification or stronger evidence?"
  ];
}

function buildExecutiveSummary(score, sectionScores) {
  const strongest = Object.entries(sectionScores).sort((a, b) => b[1].score - a[1].score)[0];
  const weakest = Object.entries(sectionScores).sort((a, b) => a[1].score - b[1].score)[0];
  const strongLabel = strongest ? prettySectionName(strongest[0]) : "core content";
  const weakLabel = weakest ? prettySectionName(weakest[0]) : "resume clarity";

  if (score >= 75) {
    return `This resume shows strong screening potential, especially in ${strongLabel}, though ${weakLabel} could still be tightened before applying widely.`;
  }

  if (score >= 50) {
    return `This resume has a solid foundation, but ${weakLabel} is currently limiting the strength of the overall case.`;
  }

  return `This resume needs more revision before broad application, with the biggest drag currently coming from ${weakLabel}.`;
}

function buildFinalVerdict(score, role) {
  if (score >= 75) {
    return `This resume is close to market-ready for ${role}, with a few refinements likely to improve recruiter confidence and ATS performance.`;
  }

  if (score >= 50) {
    return `This resume could compete for ${role}, but targeted revisions should be made before relying on it for serious applications.`;
  }

  return `This resume is not yet strong enough for ${role} submissions without major revisions to clarity, impact, and positioning.`;
}

function fallbackIndustryFit(input) {
  if (input.targetIndustry) {
    return `The resume is being evaluated against ${input.targetIndustry} expectations, with emphasis on relevance, clarity, and keyword alignment.`;
  }

  if (input.targetRole) {
    return `Industry fit is inferred mainly from the target role of ${input.targetRole} and the resume evidence provided.`;
  }

  return "Industry fit is inferred from the resume's language, projects, and professional positioning.";
}

function calculateAtsScore(checks) {
  const values = Object.values(checks);
  const passCount = values.filter(Boolean).length;
  return Math.round((passCount / values.length) * 100);
}

function prettySectionName(key) {
  const labels = {
    experience: "Experience",
    education: "Education",
    skills: "Skills",
    impact: "Impact",
    formatting: "Formatting",
    keywordFit: "Keyword Fit"
  };
  return labels[key] || key;
}

function guessCandidateName(resumeText) {
  const lines = cleanTextBlock(resumeText).split("\n");
  const firstLine = lines.find((line) => {
    const trimmed = line.trim();
    return trimmed && trimmed.length < 60 && !/@/.test(trimmed) && !/\d{3}/.test(trimmed);
  });
  return firstLine || "Candidate";
}

function guessRole(resumeText) {
  const lines = cleanTextBlock(resumeText).split("\n").slice(0, 12);
  const match = lines.find((line) =>
    /engineer|developer|analyst|manager|designer|consultant|specialist|scientist|product|marketing|sales/i.test(line)
  );
  return match || "Target role not detected";
}

function extractKeywordCandidates(text, limit) {
  const stopWords = new Set([
    "about", "after", "again", "against", "among", "application", "candidate", "company", "current", "design",
    "detail", "experience", "including", "project", "projects", "resume", "result", "responsible", "skills",
    "strong", "through", "using", "worked", "with", "your", "from", "that", "this", "there", "their", "them",
    "would", "could", "have", "will", "were", "role", "roles", "team", "teams", "summary", "education"
  ]);

  const counts = new Map();
  cleanTextBlock(text)
    .toLowerCase()
    .replace(/[^a-z0-9+.#/\s-]/g, " ")
    .split(/\s+/)
    .forEach((word) => {
      if (!word || word.length < 4 || stopWords.has(word) || /^\d+$/.test(word)) {
        return;
      }

      counts.set(word, (counts.get(word) || 0) + 1);
    });

  return [...counts.entries()]
    .sort((a, b) => b[1] - a[1])
    .slice(0, limit)
    .map(([word]) => word);
}

function cleanText(value) {
  return typeof value === "string" ? value.replace(/\s+/g, " ").trim() : "";
}

function cleanSentence(value) {
  return typeof value === "string" ? value.replace(/\s+/g, " ").trim() : "";
}

function cleanTextBlock(value) {
  return String(value || "")
    .replace(/\r/g, "")
    .replace(/[ \t]+\n/g, "\n")
    .replace(/\n{3,}/g, "\n\n")
    .trim();
}

function booleanWithFallback(value, fallback) {
  return typeof value === "boolean" ? value : Boolean(fallback);
}
