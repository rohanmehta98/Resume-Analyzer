# Copy this file to `.env.local` and fill in your key. Never commit `.env.local`.

# Groq — free tier key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model used for analysis + chat.
# IMPORTANT: analysis uses structured output (json_schema), which only works on
# newer Groq models. Recommended options (confirmed available on Groq):
#   meta-llama/llama-4-scout-17b-16e-instruct  (default — fast ~2.5s + reliable)
#   openai/gpt-oss-120b                        (deeper analysis, but slower and
#                                               occasionally retries — reasoning model)
# Do NOT use llama-3.3-70b-versatile here — it doesn't support json_schema.
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
